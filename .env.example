# ─────────────────────────────────────────────────
# Anthropic (direct API) — copy to .env and fill in
# ─────────────────────────────────────────────────

# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Default Claude model — change per pipeline as needed
# Recommended choices:
#   claude-sonnet-4-6          → best balance of speed + quality (default)
#   claude-opus-4-6            → highest capability, use for complex reasoning
#   claude-haiku-4-5-20251001  → fastest / cheapest, use for simple steps
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────
# Web API authentication
# Only needed when running the FastAPI web API (api/app.py).
# The CLI chatbot (main.py) does NOT need these.
#
# Two auth modes — configure one or the other:
#   Option A: API_KEY   — simple static key for beta / local testing
#   Option B: B2C_*     — Azure AD B2C for production (ISACA member login)
#
# If API_KEY is set, B2C config is ignored for auth.
# ─────────────────────────────────────────────────

# Option A — API key (beta / local access)
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Share the URL to beta testers as: http://localhost:8000/?key=<API_KEY>
API_KEY=

# Option B — Azure AD B2C (production member login)
# Your B2C tenant name (the part before .b2clogin.com)
B2C_TENANT_NAME=isacasdorg
# App registration Client ID from your B2C tenant
B2C_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# User Flow / policy name
B2C_POLICY_NAME=B2C_1_signupsignin

# ─────────────────────────────────────────────────
# Azure (for deployment / secrets / observability)
# ─────────────────────────────────────────────────

# Azure Container App or Function App name (used in deployment scripts)
AZURE_APP_NAME=my-pipeline-app

# Resource group where the app is deployed
AZURE_RESOURCE_GROUP=my-resource-group

# Azure region
AZURE_LOCATION=eastus

# Optional: Azure Monitor / Application Insights connection string
# Leave blank to disable telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ─────────────────────────────────────────────────
# Pipeline settings
# ─────────────────────────────────────────────────

# Max tokens Claude can use per agent turn
#   Sonnet/Opus: up to 64000 (with extended output beta)
#   Safe default for most pipelines:
MAX_TOKENS=8096

# Enable Claude extended thinking (true/false)
# Uses extra tokens but improves multi-step reasoning quality
EXTENDED_THINKING=false
THINKING_BUDGET_TOKENS=5000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
